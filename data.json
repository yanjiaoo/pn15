  "policy_timeline": [
    {
      "date": "2025-06",
      "title": "810号令 + PN15 发布",
      "description": "2025年6月，中国国务院根据第810号令发布了新的申报要求，中国国家税务总局通过2025年第15号公告(PN15)发布了实施规则。申报要求适用于所有中国境内卖家，无论在哪个亚马逊商城销售商品。",
      "type": "milestone"
    },
    {
      "date": "2025-10-31",
      "title": "首次 Q3 申报截止",
      "description": "2025年10月31日，亚马逊提交了第一份季度申报，涵盖2025年7月至9月的数据。",
      "type": "deadline"
    },
    {
      "date": "2025-12-23",
      "title": "Q3 数据邮件发送卖家",
      "description": "2025年12月23日，亚马逊通过MASS Email形式将2025年第三季度报送给税务机关的具体数据给到中国卖家。",
      "type": "notification"
    },
    {
      "date": "2026-01-30",
      "title": "退税新规第5号发布",
      "description": "2026年1月30日，国家税务总局发布《出口业务增值税和消费税退（免）税管理办法》（2026年第5号），其中提到出口货物在报关出口之日起36个月内未申报办理出口退（免）税的，将视同向境内销售货物，按规定缴纳增值税。",
      "type": "milestone"
    },
    {
      "date": "2026-02-01",
      "title": "深圳无票免税登记上线",
      "description": "2026年2月1日，深圳市跨境电商线上综合服务平台优化"无票免税"登记模块正式上线运行，企业可通过综服平台（https://www.szceb.cn/）办理"无票免税"登记，实现全流程电子化操作。是全国范围内唯一对无票免税政策有明确发文的地区，且仅针对深圳注册主体的9610出口模式卖家。",
      "type": "milestone"
    },
    {
      "date": "2026-03-26",
      "title": "Q4 数据邮件发送卖家",
      "description": "2026年3月26日，亚马逊通过MASS Email形式将2025年第四季度报送给税务机关的具体数据给到中国卖家。",
      "type": "notification"
    }
  ],
